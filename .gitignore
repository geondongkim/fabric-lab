# 의존성 패키지 (가장 중요!)
node_modules/
jspm_packages/

# 로그 파일
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# 런타임 데이터
pids/
*.pid
*.seed
*.pid.lock

# 환경 변수 및 보안 파일 (API 키, DB 비번 등)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*
!.env.example

# 빌드 결과물 및 배포 관련
dist/
build/
out/
.next/
.nuxt/
.tmp/
temp/

# 테스트 및 커버리지 리포트
coverage/
*.lcov
.nyc_output
.nyc_output/

# 에디터 및 OS 설정 파일
.vscode/
.idea/
.DS_Store
Thumbs.db

# 선택 사항: 패키지 매니저 캐시
.npm/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# 선택 사항: 기타 캐시
.eslintcache

# ──────────────────────────────────────────
# React Native / Expo (app/)
# ──────────────────────────────────────────

# Expo 메타데이터
app/.expo/
app/expo-env.d.ts
app/web-build/

# 네이티브 빌드 폴더 (EAS Build / expo prebuild 시 생성)
app/android/
app/ios/
app/.kotlin/

# Android 빌드 결과물
*.apk
*.aab
*.keystore
local.properties

# iOS 빌드 결과물
*.xcworkspace
*.xcuserstate
DerivedData/
*.ipa
*.mobileprovision
*.p12
*.p8
xcuserdata/

# 서명 키 / 인증서
*.jks
*.key
*.pem
*.cert

# Metro bundler
app/.metro-health-check*

# EAS (Expo Application Services)
.easignore

# React Native 패키지 캐시
app/.cache/

# TypeScript 빌드
*.tsbuildinfo
